{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist/server",
    "rootDir": "./src",
    "declaration": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@server/*": ["./src/server/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/server", "src/shared"],
  "exclude": ["node_modules"]
}
